{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*", 
      "**/node_modules/**",
      "firestore.rules",
      "js/admin-setup.js"
    ],
    "cleanUrls": true,
    "rewrites": [
      { "source": "/", "destination": "/index.html" },
      { "source": "/admin", "destination": "/admin/admin-panel.html" },
      { "source": "/admin/**", "destination": "/admin/admin-panel.html" },
      { "source": "/customer", "destination": "/customer/index.html" },
      { "source": "/menu", "destination": "/menu/index.html" },
      { "source": "/kitchen", "destination": "/kitchen/index.html" }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|png|jpg|jpeg|gif|svg)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=86400"
          }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}